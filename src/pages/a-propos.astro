---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { Navigation } from "../components/layout/Navigation";
import { Footer } from "../components/layout/Footer";
import { PartnersBar } from "../components/sections/PartnersBar";
import { FloatingCTA } from "../components/ui/FloatingCTA";
import Newsletter from "../components/sections/Newsletter";

const RESERVATION_URL = "https://beds24.com/booking2.php?propid=47579&referer=web";

const PARTNERS = [
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
];
---

<BaseLayout title="À propos" description="Découvrez l'histoire des Balcons — Auberge & Bistro culturel à Baie-Saint-Paul, Charlevoix." lang="fr">
  <Navigation client:load currentPath="/a-propos" lang="fr" reservationUrl={RESERVATION_URL} />

  <main>
    {/* Hero */}
    <section class="bg-[var(--color-green-dark)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px]">
        <h1 class="font-[family-name:var(--font-title)] font-extrabold text-4xl desktop:text-[length:var(--text-h1)] leading-[1.1] text-[var(--color-beige-100)] mb-6">
          À propos
        </h1>
        <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-beige-100)] max-w-[800px]">
          Les Balcons, c'est bien plus qu'une auberge. C'est un lieu de vie, de rencontres et de culture au cœur de Baie-Saint-Paul dans la magnifique région de Charlevoix.
        </p>
      </div>
    </section>

    {/* Notre histoire */}
    <section class="bg-[var(--color-beige-100)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px] flex flex-col gap-16">
        <div class="flex flex-col gap-6 max-w-[800px]">
          <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-charcoal)]">
            Notre histoire
          </h2>
          <div class="flex flex-col gap-4 font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-charcoal)]">
            <p>
              Depuis 2017, Les Balcons accueillent voyageurs, artistes et curieux dans un bâtiment historique situé au 63, rue Ambroise Fafard, en plein cœur de Baie-Saint-Paul. Ce qui a commencé comme une auberge de jeunesse abordable est devenu un véritable carrefour culturel pour la communauté.
            </p>
            <p>
              L'auberge propose des chambres privées, des dortoirs et une suite familiale, tandis que le Bistro offre une cuisine locale réconfortante, des bières de microbrasseries et une programmation culturelle vibrante — spectacles, DJ sets, événements communautaires.
            </p>
            <p>
              Que tu sois de passage pour une nuit ou pour une semaine, seul ou en groupe, Les Balcons t'offrent une expérience conviviale et authentique au cœur de Charlevoix.
            </p>
          </div>
        </div>

        {/* Valeurs */}
        <div class="flex flex-col gap-8">
          <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-charcoal)]">
            Nos valeurs
          </h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {[
              { title: "Convivialité", text: "Un lieu où tout le monde se sent chez soi, des grands espaces communs à la terrasse." },
              { title: "Culture", text: "Spectacles, art, musique — la culture est au cœur de tout ce qu'on fait." },
              { title: "Communauté", text: "Ancré dans Baie-Saint-Paul, on collabore avec les producteurs et artisans locaux." },
              { title: "Accessibilité", text: "Un hébergement de qualité à prix abordable pour tous les types de voyageurs." },
              { title: "Durabilité", text: "Des pratiques responsables pour préserver la beauté de Charlevoix." },
              { title: "Authenticité", text: "Une expérience vraie, loin des chaînes hôtelières, avec une touche personnelle." },
            ].map((value) => (
              <div class="rounded-[32px] bg-[var(--color-green-light)] p-8 flex flex-col gap-3">
                <h3 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-lg)] text-[var(--color-charcoal)]">
                  {value.title}
                </h3>
                <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-charcoal)]">
                  {value.text}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Contact rapide */}
    <section class="bg-[var(--color-charcoal)] px-4 py-16 desktop:px-24 desktop:py-20 text-center">
      <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-beige-100)] mb-4">
        Viens nous voir!
      </h2>
      <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-beige-100)]/80 mb-2">
        63 Rue Ambroise Fafard, Baie-Saint-Paul, QC G3Z 2J7
      </p>
      <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-beige-100)]/80 mb-8">
        <a href="tel:+15817052176" class="underline hover:opacity-70">+1 581-705-2176</a> · <a href="mailto:info@lesbalcons.ca" class="underline hover:opacity-70">info@lesbalcons.ca</a>
      </p>
      <a
        href={RESERVATION_URL}
        target="_blank"
        class="inline-flex items-center justify-center rounded-full bg-[var(--color-yellow-500)] px-8 py-4 font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-charcoal)] transition-opacity hover:opacity-80"
      >
        Je réserve
      </a>
    </section>

    <Newsletter client:load />
  </main>

  <Footer client:load lang="fr" />
  <PartnersBar partners={PARTNERS} />
  <FloatingCTA href={RESERVATION_URL} />
</BaseLayout>
