---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { Navigation } from "../components/layout/Navigation";
import { Footer } from "../components/layout/Footer";
import { PartnersBar } from "../components/sections/PartnersBar";
import { FloatingCTA } from "../components/ui/FloatingCTA";
import Newsletter from "../components/sections/Newsletter";

const RESERVATION_URL = "https://beds24.com/booking2.php?propid=47579&referer=web";

const PARTNERS = [
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
];

const EVENT_TYPES = [
  {
    title: "Spectacles live",
    text: "Musique locale et régionale tous les weekends. Rock, folk, jazz, chanson québécoise — une programmation variée pour toutes les oreilles.",
  },
  {
    title: "DJ sets",
    text: "Les jeudis soirs, le Bistro se transforme en piste de danse avec des DJ sets électro, house et bien plus encore.",
  },
  {
    title: "Événements communautaires",
    text: "Vernissages, lancements de livres, soirées thématiques — le Bistro est un carrefour culturel ancré dans la communauté de Baie-Saint-Paul.",
  },
  {
    title: "Événements spontanés",
    text: "La vie aux Balcons est pleine de surprises. Garde un œil sur notre page Facebook pour ne rien manquer des événements de dernière minute.",
  },
];
---

<BaseLayout title="Événements" description="Événements et programmation culturelle aux Balcons — Spectacles, DJ sets, soirées communautaires à Baie-Saint-Paul." lang="fr">
  <Navigation client:load currentPath="/evenements" lang="fr" reservationUrl={RESERVATION_URL} />

  <main>
    {/* Hero section — purple */}
    <section class="bg-[var(--color-purple-500)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px]">
        <h1 class="font-[family-name:var(--font-title)] font-extrabold text-4xl desktop:text-[length:var(--text-h1)] leading-[1.1] text-[var(--color-charcoal)] mb-6">
          Événements
        </h1>
        <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-charcoal)] max-w-[800px]">
          Le Bistro des Balcons est bien plus qu'un bar — c'est un lieu de vie culturelle. Spectacles, DJ sets, soirées communautaires et événements spontanés rythment la vie du lieu à l'année. Consulte notre page Facebook pour la programmation complète et à jour.
        </p>
      </div>
    </section>

    {/* Types d'événements */}
    <section class="bg-[var(--color-beige-100)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px] flex flex-col gap-12">
        <div class="flex flex-col gap-4 max-w-[800px]">
          <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-charcoal)]">
            Notre programmation
          </h2>
          <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-charcoal)]">
            Chaque semaine, le Bistro s'anime avec une programmation culturelle variée. Voici ce que tu peux retrouver au fil de l'année.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {EVENT_TYPES.map((event) => (
            <div class="rounded-[32px] bg-[var(--color-green-light)] p-8 flex flex-col gap-3">
              <h3 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-lg)] text-[var(--color-charcoal)]">
                {event.title}
              </h3>
              <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-charcoal)]">
                {event.text}
              </p>
            </div>
          ))}
        </div>

        {/* CMS notice */}
        <div class="rounded-[32px] bg-[var(--color-purple-500)]/20 border border-[var(--color-purple-500)]/30 p-8">
          <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-sm)] text-[var(--color-charcoal)]/70">
            Note : Les événements dynamiques seront gérés via Sanity CMS et affichés automatiquement ici prochainement.
          </p>
        </div>
      </div>
    </section>

    {/* CTA Facebook */}
    <section class="bg-[var(--color-charcoal)] px-4 py-16 desktop:px-24 desktop:py-20 text-center">
      <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-beige-100)] mb-6">
        Voir la programmation complète
      </h2>
      <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-beige-100)]/80 mb-8 mx-auto max-w-[600px]">
        Tous nos événements sont publiés en temps réel sur notre page Facebook. Suis-nous pour ne rien manquer!
      </p>
      <a
        href="https://www.facebook.com/aubergedesbalcons"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[var(--color-purple-500)] px-8 py-4 font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-charcoal)] transition-opacity hover:opacity-80"
      >
        Voir les événements sur Facebook
      </a>
    </section>

    <Newsletter client:load />
  </main>

  <Footer client:load lang="fr" />
  <PartnersBar partners={PARTNERS} />
  <FloatingCTA href={RESERVATION_URL} />
</BaseLayout>
