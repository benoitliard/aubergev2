---
export const prerender = true;
import { sanityClient } from "sanity:client";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Navigation } from "../components/layout/Navigation";
import { Footer } from "../components/layout/Footer";
import { PartnersBar } from "../components/sections/PartnersBar";
import { FloatingCTA } from "../components/ui/FloatingCTA";
import Newsletter from "../components/sections/Newsletter";

const RESERVATION_URL = "https://beds24.com/booking2.php?propid=47579&referer=web";

const PARTNERS = [
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
  { name: "SODEC Québec", logo: "/partners/sodec-quebec.png", url: "https://www.sodec.gouv.qc.ca" },
  { name: "Desjardins", logo: "/partners/desjardins.png", url: "https://www.desjardins.com" },
];

// Fetch only upcoming events (date >= now)
const now = new Date().toISOString();
const events = await sanityClient.fetch(
  `*[_type == "event" && date >= $now] | order(date asc) {
    "title": title.fr,
    "description": description.fr,
    "slug": slug.current,
    date,
    endDate,
    category,
    facebookEventUrl,
    ticketUrl,
    "imageUrl": image.asset->url
  }`,
  { now }
);

const CATEGORY_LABELS: Record<string, { label: string; color: string }> = {
  musique: { label: "Musique", color: "var(--color-purple-500)" },
  spectacle: { label: "Spectacle", color: "var(--color-yellow-500)" },
  communautaire: { label: "Communautaire", color: "var(--color-green-light)" },
  autre: { label: "Autre", color: "var(--color-beige-100)" },
};

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("fr-CA", {
    weekday: "long",
    day: "numeric",
    month: "long",
  });
}

function formatTime(dateStr: string): string {
  return new Date(dateStr).toLocaleTimeString("fr-CA", {
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<BaseLayout title="Événements" description="Programmation culturelle des Balcons — Spectacles, DJ sets, marchés et événements communautaires à Baie-Saint-Paul." lang="fr">
  <Navigation client:load currentPath="/evenements" lang="fr" reservationUrl={RESERVATION_URL} />

  <main>
    {/* Hero — purple */}
    <section class="bg-[var(--color-purple-500)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px]">
        <h1 class="font-[family-name:var(--font-title)] font-extrabold text-4xl desktop:text-[length:var(--text-h1)] leading-[1.1] text-[var(--color-charcoal)] mb-6">
          Événements
        </h1>
        <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-charcoal)] max-w-[800px]">
          Lieu de vie bien ancré dans sa communauté, le Bistro te propose une programmation culturelle variée — spectacles, DJ sets, marchés artisanaux et événements spontanés.
        </p>
      </div>
    </section>

    {/* Events list from Sanity */}
    <section class="bg-[var(--color-beige-100)] px-4 py-16 desktop:px-24 desktop:py-[88px]">
      <div class="mx-auto max-w-[1102px]">
        <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-charcoal)] mb-10">
          Prochains événements
        </h2>

        {events.length > 0 ? (
          <div class="flex flex-col gap-6">
            {events.map((event: any) => {
              const cat = CATEGORY_LABELS[event.category] || CATEGORY_LABELS.autre;
              return (
                <article class="flex flex-col lg:flex-row gap-6 rounded-[32px] bg-white p-6 lg:p-8">
                  {/* Date block */}
                  <div class="flex shrink-0 flex-col items-center justify-center rounded-2xl bg-[var(--color-green-dark)] px-6 py-4 text-center lg:w-[140px]">
                    <span class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1] text-[var(--color-beige-100)]">
                      {new Date(event.date).getDate()}
                    </span>
                    <span class="font-[family-name:var(--font-body)] text-[length:var(--text-body-sm)] text-[var(--color-beige-100)] uppercase">
                      {new Date(event.date).toLocaleDateString("fr-CA", { month: "short" })}
                    </span>
                  </div>

                  {/* Content */}
                  <div class="flex flex-1 flex-col gap-3">
                    <span
                      class="inline-flex w-fit items-center rounded-full px-3 py-1 font-[family-name:var(--font-title)] font-extrabold text-[13px] text-[var(--color-charcoal)]"
                      style={`background-color: ${cat.color}`}
                    >
                      {cat.label}
                    </span>

                    <h3 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-lg)] leading-[1.3] text-[var(--color-charcoal)]">
                      {event.title}
                    </h3>

                    <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-sm)] text-[var(--color-charcoal)]/70">
                      {formatDate(event.date)} · {formatTime(event.date)}
                      {event.endDate && ` — ${formatTime(event.endDate)}`}
                    </p>

                    <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] leading-[1.5] text-[var(--color-charcoal)]">
                      {event.description}
                    </p>

                    <div class="flex flex-wrap gap-4 mt-2">
                      {event.facebookEventUrl && (
                        <a
                          href={event.facebookEventUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-green-dark)] underline hover:opacity-70"
                        >
                          Voir sur Facebook
                        </a>
                      )}
                      {event.ticketUrl && (
                        <a
                          href={event.ticketUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center rounded-full bg-[var(--color-charcoal)] px-5 py-2 font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-beige-100)] hover:opacity-80"
                        >
                          Acheter des billets
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="rounded-[32px] bg-white p-12 text-center">
            <p class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-lg)] text-[var(--color-charcoal)] mb-4">
              Aucun événement à venir pour le moment
            </p>
            <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-charcoal)]/70 mb-6">
              Suis-nous sur Facebook pour être au courant des prochains événements!
            </p>
            <a
              href="https://www.facebook.com/aubergedesbalcons"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-[var(--color-purple-500)] px-6 py-3 font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-charcoal)] transition-opacity hover:opacity-80"
            >
              Suivre sur Facebook
            </a>
          </div>
        )}
      </div>
    </section>

    {/* CTA — propose a show */}
    <section class="bg-[var(--color-charcoal)] px-4 py-16 desktop:px-24 desktop:py-20 text-center">
      <h2 class="font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-h4)] leading-[1.2] text-[var(--color-beige-100)] mb-4">
        Tu veux proposer un spectacle?
      </h2>
      <p class="font-[family-name:var(--font-body)] text-[length:var(--text-body-md)] text-[var(--color-beige-100)]/80 mb-8 mx-auto max-w-[600px]">
        Musiciens, humoristes, artistes — on cherche toujours de nouveaux talents pour notre programmation.
      </p>
      <a
        href="mailto:info@lesbalcons.ca"
        class="inline-flex items-center justify-center rounded-full bg-[var(--color-purple-500)] px-8 py-4 font-[family-name:var(--font-title)] font-extrabold text-[length:var(--text-body-sm)] text-[var(--color-charcoal)] transition-opacity hover:opacity-80"
      >
        Proposer un spectacle
      </a>
    </section>

    <Newsletter client:load />
  </main>

  <Footer client:load lang="fr" />
  <PartnersBar partners={PARTNERS} />
  <FloatingCTA href={RESERVATION_URL} />
</BaseLayout>
