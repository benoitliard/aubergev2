---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: "fr" | "en";
}

const { title, description = "Les Balcons — Auberge & Bistro culturel à Baie-Saint-Paul, Charlevoix", lang = "fr" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75..100,200..800&display=swap" rel="stylesheet" />
    <link rel="preload" href="/fonts/ExtraChunkPlease-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title} | Les Balcons</title>
  </head>
  <body>
    <slot />
  </body>
</html>
